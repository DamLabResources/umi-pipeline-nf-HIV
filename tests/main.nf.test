nextflow_pipeline {

    name "Test Workflow main.nf"
    script "main.nf"

    test("Should execute umi-pipeline-nf - POA-based") {

        when {

            params {
                input 			            = "$baseDir/tests/input/pipeline/fastq_pass/"
                output 			            = "test_umi-pipeline-nf"
                reference 		            = "$baseDir/tests/input/pipeline/ref/lpa-ref2645.fasta"
                reference_fai 	            = "$baseDir/tests/input/pipeline/ref/lpa-ref2645.fasta.fai"
                bed 			            = "$baseDir/tests/input/pipeline/ref/lpa-ref2645.bed"

                min_reads_per_cluster 	    = 10
                max_reads_per_cluster 	    = 10
                min_reads_per_barcode       = 0
                reference_based_polishing   = false
                call_variants 		        = true
                variant_caller 		        = "freebayes"
            }
        }

        then {
            assert workflow.success
        }

    }

    test("Should execute umi-pipeline-nf - reference-based") {

        when {

            params {
                input 			            = "$baseDir/tests/input/pipeline/fastq_pass/"
                output 			            = "test_umi-pipeline-nf"
                reference 		            = "$baseDir/tests/input/pipeline/ref/lpa-ref2645.fasta"
                reference_fai 	            = "$baseDir/tests/input/pipeline/ref/lpa-ref2645.fasta.fai"
                bed 			            = "$baseDir/tests/input/pipeline/ref/lpa-ref2645.bed"

                min_reads_per_cluster 	    = 10
                max_reads_per_cluster 	    = 10
                min_reads_per_barcode       = 0
                reference_based_polishing   = true
                call_variants 		        = true
                variant_caller 		        = "freebayes"
            }
        }

        then {
            assert workflow.success
        }

    }

    test("Should execute umi-pipeline-nf with one sample - reference-based") {

        when {

            params {
                input 			            = "$baseDir/tests/input/pipeline/fastq_pass/barcode06"
                output 			            = "test_umi-pipeline-nf"
                reference 		            = "$baseDir/tests/input/pipeline/ref/lpa-ref2645.fasta"
                reference_fai 	            = "$baseDir/tests/input/pipeline/ref/lpa-ref2645.fasta.fai"
                bed 			            = "$baseDir/tests/input/pipeline/ref/lpa-ref2645.bed"

                single_sample               = true
                min_reads_per_cluster 	    = 10
                max_reads_per_cluster 	    = 10
                min_reads_per_barcode       = 0
                reference_based_polishing   = true
                call_variants 		        = true
                variant_caller 		        = "freebayes"
            }
        }

        then {
            assert workflow.success
        }

    }

    test("Should execute umi-pipeline-nf - SIVmac239m2 smoke") {

        when {

            params {
                input                          = "$baseDir/tests/input/pipeline/sivmac_smoke/fastq_pass"
                output                         = "test_umi-pipeline-nf-sivmac"
                reference                      = "$baseDir/tests/input/sivmac239m2/sivmac239m2.ltr_masked.fa"
                reference_fai                  = "$baseDir/tests/input/sivmac239m2/sivmac239m2.ltr_masked.fa.fai"
                bed                            = "$baseDir/tests/input/sivmac239m2/sivmac239m2_combined.bed"
                min_reads_per_barcode          = 0
                min_reads_per_cluster          = 2
                max_reads_per_cluster          = 20
                min_length                     = 16
                max_length                     = 60
                balance_strands                = false
                use_context                    = true
                fwd_umi                        = "ACGTACGTACGTACGTAC"
                rev_umi                        = "TGCATGCATGCATGCATG"
                fwd_context                    = "CAAGCAGAAGACGGCATACGAGAT"
                rev_context                    = "TAGGGAGCCGTCAGGATCAG"
                split_read_filter_mode         = "deletion_tolerant"
                cluster_by_amplicon_length     = true
                max_amplicon_length_diff_bp    = 100
                max_amplicon_length_diff_pct   = 15
                reference_based_polishing      = false
                call_variants                  = false
            }
        }

        then {
            assert workflow.success
        }

    }
}