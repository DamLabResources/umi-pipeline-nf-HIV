/*
 * Example profile for integrated SIVmac239m2 / lentivirus UMI amplicons.
 * Adjust paths, UMI sequences, and thresholds for your run.
 */

params {
    reference                      = "sivmac239m2.ltr_masked.fa"
    reference_fai                  = "sivmac239m2.ltr_masked.fa.fai"
    bed                            = "sivmac239m2_combined.bed"

    min_length                     = 16
    balance_strands                = false
    use_context                    = true
    fwd_umi                        = "NNNYRNNNYRNNNYRNNN"
    rev_umi                        = "NNNYRNNNYRNNNYRNNN"
    fwd_context                    = "CAAGCAGAAGACGGCATACGAGAT"
    rev_context                    = "TAGGGAGCCGTCAGGATCAG"

    split_read_filter_mode         = "deletion_tolerant"
    min_overlap                    = 0.95

    cluster_by_amplicon_length     = true
    max_amplicon_length_diff_bp    = 150
    max_amplicon_length_diff_pct   = 10

    reference_based_polishing      = false
}
